// ============================================================
// MOTOR FUNCTIONS
// ============================================================

void stopMotor() {
  ledcWrite(MOTOR_ENB, 0);

  digitalWrite(MOTOR_IN3, LOW);
  digitalWrite(MOTOR_IN4, LOW);
}

void driveMotorRaw(bool forward, int speedValue) {
  speedValue = constrain(speedValue, 0, 255);

  bool actualForward = forward;

  if (REVERSE_MOTOR_DIRECTION) {
    actualForward = !actualForward;
  }

  if (actualForward) {
    digitalWrite(MOTOR_IN3, HIGH);
    digitalWrite(MOTOR_IN4, LOW);
  } else {
    digitalWrite(MOTOR_IN3, LOW);
    digitalWrite(MOTOR_IN4, HIGH);
  }

  ledcWrite(MOTOR_ENB, speedValue);
}

void moveForward(int speedValue) {
  driveMotorRaw(true, speedValue);
}

void moveBackward(int speedValue) {
  driveMotorRaw(false, speedValue);
}

