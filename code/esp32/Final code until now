// ============================================================
// MPU6050 / GYROSCOPE SETTINGS
// ============================================================

/*
  MPU6050 wiring through the I2C expansion board:
  VCC -> 3.3V
  GND -> common GND
  SDA -> GPIO21
  SCL -> GPIO22

  The MPU6050 uses its normal I2C address 0x68.
  The three VL6180X sensors are moved to 0x30, 0x31 and 0x32,
  so there is no I2C address conflict.

  Keep the vehicle completely still during startup calibration.
*/

bool imuReady = false;
float currentYawDeg = 0.0;
float roundHeadingDeg = 0.0;
float cornerStartYawDeg = 0.0;
float obstacleStartYawDeg = 0.0;

unsigned long previousImuTime = 0;
const unsigned long IMU_UPDATE_INTERVAL_MS = 5;

// A car normally starts leaving the corner before a full 90 degrees.
// Tune this between about 72 and 88 degrees on the real field.
const float CORNER_EXIT_ANGLE_DEG = 80.0;

// Gyroscope safety fallback. The existing distance/time conditions
// remain active if the IMU is missing or a turn does not reach the angle.
const bool USE_IMU_FOR_CORNER_EXIT = true;

float absoluteYawChange(float startAngle, float currentAngle) {
  return fabs(currentAngle - startAngle);
}

void updateIMU() {
  if (!imuReady) {
    return;
  }

  unsigned long now = millis();

  if (now - previousImuTime < IMU_UPDATE_INTERVAL_MS) {
    return;
  }

  previousImuTime = now;
  mpu.update();
  currentYawDeg = mpu.getAngleZ();
}

bool initializeMPU6050() {
  Serial.println("Initializing MPU6050 at I2C address 0x68...");

  byte status = mpu.begin();

  if (status != 0) {
    Serial.print("WARNING: MPU6050 initialization failed, status=");
    Serial.println(status);
    Serial.println("Robot will continue using ToF/time fallbacks.");
    imuReady = false;
    return false;
  }

  Serial.println("Keep the robot completely still: calibrating MPU6050...");
  delay(500);

  // Calculates gyro and accelerometer offsets.
  mpu.calcOffsets(true, true);

  mpu.update();
  currentYawDeg = mpu.getAngleZ();
  roundHeadingDeg = currentYawDeg;
  imuReady = true;

  Serial.println("MPU6050 ready.");
  return true;
}


