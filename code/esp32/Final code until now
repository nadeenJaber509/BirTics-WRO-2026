}

void updateServoSmoothly() {
  unsigned long now = millis();

  if (now - previousServoTime < SERVO_INTERVAL_MS) {
    return;
  }

  previousServoTime = now;

  if (currentServoAngle < targetServoAngle) {
    currentServoAngle++;
  } else if (currentServoAngle > targetServoAngle) {
    currentServoAngle--;
  }

  currentServoAngle = constrain(
    currentServoAngle,
    SERVO_FULL_LEFT,
    SERVO_FULL_RIGHT
  );

  steeringServo.write(currentServoAngle);
}

// ============================================================
